{
  "name": "@sumit-ingale-aot/admin-portal-components",
  "version": "0.1.8",
  "description": "This library contains the login and forgot password microfrontend for admins portals",
  "author": {
    "name": "Sumit Ingale",
    "email": "sumit.ingale@algoocean.com"
  },
  "module": "dist/index.mjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:css": "npx @tailwindcss/cli -i ./src/styles/globals.css -o ./dist/styles.css",
    "build:lib": "tsup && npm run build:css",
    "start": "next start",
    "lint": "eslint"
  },
  "peerDependencies": {
    "@radix-ui/react-dialog": ">=1",
    "axios": ">=1",
    "class-variance-authority": ">=0.7.0",
    "clsx": ">=2",
    "lucide-react": ">=0.300.0",
    "next": ">=12",
    "react": ">=17",
    "react-dom": ">=17",
    "react-hook-form": ">=7",
    "sonner": ">=1",
    "tailwind-merge": ">=2",
    "zod": ">=3",
    "zustand": ">=4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4.3.1",
    "tsup": "^8",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.mjs",
      "require": "./dist/server.js"
    },
    "./styles.css": "./dist/styles.css"
  }
}